{
  "expo": {
    "name": "PicoClaw",
    "slug": "picoclaw-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.picoclaw.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PicoClaw uses your location to give context-aware suggestions.",
        "NSCalendarsUsageDescription": "PicoClaw reads your calendar to help you stay on top of your schedule.",
        "NSMicrophoneUsageDescription": "PicoClaw uses your microphone for voice messages.",
        "NSCameraUsageDescription": "PicoClaw uses your camera to share images with your agent."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.picoclaw.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_CALENDAR",
        "RECORD_AUDIO",
        "CAMERA"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "picoclaw",
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ]
    ]
  }
}
