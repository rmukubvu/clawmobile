{
  "expo": {
    "name": "ClawMobile",
    "slug": "clawmobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clawmobile.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ClawMobile uses your location to give context-aware suggestions.",
        "NSCalendarsUsageDescription": "ClawMobile reads your calendar to help you stay on top of your schedule.",
        "NSMicrophoneUsageDescription": "ClawMobile uses your microphone for voice messages.",
        "NSCameraUsageDescription": "ClawMobile uses your camera to share images with your agent."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.clawmobile.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_CALENDAR",
        "RECORD_AUDIO",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "scheme": "clawmobile",
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb95b95b-ca4c-4732-93f6-830c25fccc6f"
      }
    }
  }
}
